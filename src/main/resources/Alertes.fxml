<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1240.0"
            styleClass="pro-page-root" stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Alertes">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="pro-page-header">
            <Button onAction="#retour" styleClass="pro-back-btn" text="◀"/>
            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                <Label styleClass="pro-page-title-big" text="Alertes intelligentes"/>
                <Label styleClass="pro-page-sub-big"
                       text="Détection automatique des situations à surveiller"/>
            </VBox>
            <Button fx:id="btnScan" onAction="#lancerScan" prefHeight="42"
                    styleClass="pro-btn-primary" text="✨  Scan intelligent"/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <VBox spacing="18" style="-fx-padding: 24 32 0 32; -fx-background-color: #0f0f1e;">

            <!-- Stats row -->
            <HBox spacing="14">
                <VBox styleClass="pro-stat-card,pro-stat-red" HBox.hgrow="ALWAYS">
                    <Label styleClass="pro-stat-label" text="🔴 Critiques"/>
                    <Label fx:id="lbCritiques" styleClass="pro-stat-value,pro-red-text" text="0"/>
                </VBox>
                <VBox styleClass="pro-stat-card,pro-stat-violet" HBox.hgrow="ALWAYS">
                    <Label styleClass="pro-stat-label" text="🟠 Moyennes"/>
                    <Label fx:id="lbMoyennes" styleClass="pro-stat-value"
                           style="-fx-text-fill:#f59e0b;" text="0"/>
                </VBox>
                <VBox styleClass="pro-stat-card,pro-stat-green" HBox.hgrow="ALWAYS">
                    <Label styleClass="pro-stat-label" text="🟢 Positives"/>
                    <Label fx:id="lbPositives" styleClass="pro-stat-value,pro-green-text" text="0"/>
                </VBox>
                <VBox styleClass="pro-stat-card,pro-stat-blue" HBox.hgrow="ALWAYS">
                    <Label styleClass="pro-stat-label" text="🔵 Infos"/>
                    <Label fx:id="lbInfos" styleClass="pro-stat-value,pro-blue-text" text="0"/>
                </VBox>
                <VBox styleClass="pro-stat-card,pro-stat-violet" HBox.hgrow="ALWAYS">
                    <Label styleClass="pro-stat-label" text="🔔 Nouvelles"/>
                    <Label fx:id="lbNouvelles" styleClass="pro-stat-value,pro-violet-text" text="0"/>
                </VBox>
            </HBox>

            <!-- Filtres -->
            <VBox spacing="14" styleClass="pro-card-block">
                <Label styleClass="pro-block-title" text="🔍  Filtres"/>
                <HBox alignment="BOTTOM_LEFT" spacing="14">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="pro-label" text="SÉVÉRITÉ"/>
                        <ComboBox fx:id="cbSeverite" maxWidth="1.7976931348623157E308"
                                  prefHeight="40" promptText="Toutes"
                                  styleClass="pro-combo"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label styleClass="pro-label" text="STATUT"/>
                        <ComboBox fx:id="cbStatut" maxWidth="1.7976931348623157E308"
                                  prefHeight="40" promptText="Tous"
                                  styleClass="pro-combo"/>
                    </VBox>
                    <Button onAction="#filtrer" prefHeight="40"
                            styleClass="pro-btn-primary" text="🔍  Filtrer"/>
                    <Button onAction="#reset" prefHeight="40"
                            styleClass="pro-btn-secondary" text="↻  Reset"/>
                </HBox>
            </VBox>

            <!-- Liste alertes en cards -->
            <ListView fx:id="lvAlertes" styleClass="pro-cards-list" VBox.vgrow="ALWAYS"/>

            <!-- Détails sélection -->
            <VBox spacing="6" styleClass="pro-card-block">
                <Label styleClass="pro-label" text="MESSAGE DÉTAILLÉ"/>
                <Label fx:id="lbMessage" styleClass="pro-hint" wrapText="true"
                       text="Sélectionner une alerte pour voir les détails."/>
            </VBox>
        </VBox>
    </center>

    <!-- Actions footer -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #16162e; -fx-padding: 16 32; -fx-border-color: #2d2d4e; -fx-border-width: 1 0 0 0;">
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#marquerLue"     styleClass="pro-btn-secondary" text="✓  Marquer lue"/>
            <Button onAction="#marquerTraitee" styleClass="pro-btn-success"   text="✔  Traitée"/>
            <Button onAction="#ignorer"        styleClass="pro-btn-secondary" text="✕  Ignorer"/>
            <Button onAction="#supprimer"      styleClass="pro-btn-danger"    text="🗑  Supprimer"/>
        </HBox>
    </bottom>
</BorderPane>
