<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>

<VBox fx:id="mainContainer"
      spacing="0"
      style="-fx-padding: 0;
             -fx-background-color: #ffffff;"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edunova.connexion.controllers.GoogleOAuth2WindowController">

    <!-- Barre de titre -->
    <HBox style="-fx-background-color: #6a0dad;
                 -fx-padding: 12;
                 -fx-alignment: CENTER_LEFT;">
        <Label fx:id="lblTitle"
               text="🔐 Connexion Google"
               style="-fx-font-size: 14;
                      -fx-font-weight: bold;
                      -fx-text-fill: white;"/>
    </HBox>

    <!-- WebView pour afficher la page de connexion Google -->
    <WebView fx:id="webView"
             VBox.vgrow="ALWAYS"
             style="-fx-font-size: 12;"/>

    <!-- Barre de boutons -->
    <HBox spacing="10"
          style="-fx-padding: 12;
                 -fx-background-color: #f0f2f5;
                 -fx-alignment: CENTER_RIGHT;
                 -fx-border-color: #e2e8f0;
                 -fx-border-width: 1 0 0 0;">
        <Button fx:id="btnCancel"
                text="Annuler"
                style="-fx-background-color: #e2e8f0;
                       -fx-text-fill: #1e293b;
                       -fx-padding: 8 20;
                       -fx-font-size: 12;
                       -fx-border-radius: 5;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>
