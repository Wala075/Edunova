<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="780.0" prefWidth="1180.0"
            styleClass="pro-page-root" stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Bulletin">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="pro-page-header">
            <Button onAction="#retour" styleClass="pro-back-btn" text="◀"/>
            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                <Label styleClass="pro-page-title-big" text="Bulletin scolaire"/>
                <Label styleClass="pro-page-sub-big"
                       text="Générer le bulletin d'un élève pour un trimestre donné"/>
            </VBox>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="pro-page-content">
            <VBox spacing="18" style="-fx-padding: 24 32 24 32;">

                <!-- Card Sélection -->
                <VBox spacing="14" styleClass="pro-card-block">
                    <Label styleClass="pro-block-title" text="🎯  Sélection"/>

                    <HBox alignment="BOTTOM_LEFT" spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="ÉLÈVE"/>
                            <ComboBox fx:id="cbEleve" maxWidth="1.7976931348623157E308"
                                      prefHeight="40" promptText="Sélectionner un élève"
                                      styleClass="pro-combo"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label styleClass="pro-label" text="TRIMESTRE"/>
                            <ComboBox fx:id="cbTrimestre" prefHeight="40" prefWidth="130"
                                      promptText="Trimestre" styleClass="pro-combo"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label styleClass="pro-label" text="ANNÉE SCOLAIRE"/>
                            <TextField fx:id="tfAnnee" prefHeight="40" prefWidth="140"
                                       styleClass="pro-input" text="2024-2025"/>
                        </VBox>
                        <Button onAction="#genererBulletin" prefHeight="40"
                                styleClass="pro-btn-primary" text="✨  Générer"/>
                    </HBox>
                </VBox>

                <!-- Hero result -->
                <HBox alignment="CENTER_LEFT" spacing="20" styleClass="pro-hero">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label fx:id="lbEleve" styleClass="pro-hero-name" text="—"/>
                        <Label fx:id="lbInfos" styleClass="pro-hero-info"
                               text="Sélectionnez un élève puis cliquez sur Générer"/>
                    </VBox>
                    <VBox alignment="CENTER_RIGHT" spacing="6">
                        <Label styleClass="pro-label" text="MOYENNE GÉNÉRALE"/>
                        <Label fx:id="lbMoyenne" styleClass="pro-hero-mark" text="—"/>
                        <Label fx:id="lbMention" styleClass="pro-hero-mention" text=""/>
                    </VBox>
                </HBox>

                <!-- Notes table -->
                <TableView fx:id="tvBulletin" prefHeight="240" styleClass="pro-table">
                    <columns>
                        <TableColumn fx:id="colMatiere" prefWidth="320.0" text="Matière"/>
                        <TableColumn fx:id="colNbNotes" prefWidth="130.0" text="Nb notes"/>
                        <TableColumn fx:id="colMoyenne" prefWidth="170.0" text="Moyenne / 20"/>
                        <TableColumn fx:id="colAppreciation" prefWidth="260.0" text="Appréciation"/>
                    </columns>
                </TableView>

                <!-- Card Appréciation IA (Gemini) -->
                <VBox spacing="10" styleClass="pro-card-block">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="pro-block-title" text="✨  Appréciation"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressIndicator fx:id="aiSpinner" maxHeight="22.0"
                                           maxWidth="22.0" visible="false"/>
                        <Button fx:id="btnReformuler" onAction="#reformulerAppreciation"
                                prefHeight="38" styleClass="pro-btn-primary"
                                text="🪄  Améliorer mon texte"/>
                        <Button fx:id="btnGenererIA" onAction="#genererAppreciationIA"
                                prefHeight="38" styleClass="pro-btn-secondary"
                                text="✨  Générer depuis bulletin"/>
                        <Button fx:id="btnRegenerer" onAction="#genererAppreciationIA"
                                prefHeight="38" styleClass="pro-btn-secondary"
                                text="↻  Régénérer" visible="false" managed="false"/>
                    </HBox>
                    <Label styleClass="pro-hint"
                           text="✏ Tape ton texte ci-dessous puis clique '🪄 Améliorer mon texte' pour qu'il soit corrigé et reformulé professionnellement."/>
                    <TextArea fx:id="taAppreciationIA" prefRowCount="5" wrapText="true"
                              promptText="Saisis ici ton appréciation (l'IA corrigera l'orthographe, la grammaire et reformulera de manière professionnelle)..."
                              styleClass="pro-text-area"/>
                </VBox>

                <!-- Card Version Arabe (DeepL) -->
                <VBox fx:id="boxArabe" spacing="10" styleClass="pro-card-block"
                      visible="false" managed="false">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="pro-block-title" text="🇹🇳  النسخة العربية"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressIndicator fx:id="arSpinner" maxHeight="22.0"
                                           maxWidth="22.0" visible="false"/>
                        <Button fx:id="btnTraduireAr" onAction="#traduireEnArabe"
                                prefHeight="38" styleClass="pro-btn-primary"
                                text="🇹🇳  Version arabe"/>
                        <Button fx:id="btnRetraduireAr" onAction="#traduireEnArabe"
                                prefHeight="38" styleClass="pro-btn-secondary"
                                text="↻  Retraduire" visible="false" managed="false"/>
                    </HBox>
                    <TextArea fx:id="taAppreciationAr" prefRowCount="4" wrapText="true"
                              promptText="انقر فوق &quot;الترجمة العربية&quot; للحصول على النسخة العربية"
                              nodeOrientation="RIGHT_TO_LEFT"
                              styleClass="pro-text-area,pro-arabic-text"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <!-- Footer actions -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #16162e; -fx-padding: 16 32; -fx-border-color: #2d2d4e; -fx-border-width: 1 0 0 0;">
            <Label fx:id="lbDecision" styleClass="pro-hero-mention" text=""/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnImprimerPdf" onAction="#imprimerPdf"
                    prefHeight="40" styleClass="pro-btn-secondary"
                    text="📄  Imprimer PDF"/>
            <Button fx:id="btnEnvoyerParents" onAction="#envoyerAuxParents"
                    prefHeight="40" styleClass="pro-btn-primary"
                    text="📧  Envoyer aux parents"/>
        </HBox>
    </bottom>
</BorderPane>
