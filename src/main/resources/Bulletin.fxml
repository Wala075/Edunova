<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox prefHeight="740.0" prefWidth="1080.0" spacing="22.0"
      styleClass="app-root" stylesheets="@dashboard.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.Bulletin">
    <padding><Insets bottom="36.0" left="40.0" right="40.0" top="36.0"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="14.0">
        <Button onAction="#retour" styleClass="back-btn" text="◀"/>
        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
            <Label styleClass="app-title" text="Bulletin scolaire"/>
            <Label styleClass="app-subtitle" text="Générer le bulletin d'un élève pour un trimestre donné"/>
        </VBox>
    </HBox>

    <!-- Mint pastel selection card -->
    <VBox spacing="14.0" styleClass="pastel-mint">
        <padding><Insets bottom="22.0" left="22.0" right="22.0" top="20.0"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="card-tag">
                <Label text="🎯"/>
                <Label styleClass="card-tag-text" text="Sélection"/>
            </HBox>
        </HBox>

        <HBox alignment="BOTTOM_LEFT" spacing="14.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label styleClass="label-on-pastel" text="ÉLÈVE"/>
                <ComboBox fx:id="cbEleve" maxWidth="1.7976931348623157E308" prefHeight="40.0"
                          promptText="Sélectionner un élève" styleClass="combo-pill"/>
            </VBox>
            <VBox spacing="6.0">
                <Label styleClass="label-on-pastel" text="TRIMESTRE"/>
                <ComboBox fx:id="cbTrimestre" prefHeight="40.0" prefWidth="130.0"
                          promptText="Trimestre" styleClass="combo-pill"/>
            </VBox>
            <VBox spacing="6.0">
                <Label styleClass="label-on-pastel" text="ANNÉE SCOLAIRE"/>
                <TextField fx:id="tfAnnee" prefHeight="40.0" prefWidth="140.0" styleClass="input-pill" text="2024-2025"/>
            </VBox>
            <Button onAction="#genererBulletin" prefHeight="40.0" styleClass="btn-primary" text="✨  Générer"/>
        </HBox>
    </VBox>

    <!-- Pink hero result card -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="pastel-pink">
        <padding><Insets bottom="22.0" left="26.0" right="26.0" top="22.0"/></padding>

        <StackPane>
            <Circle fill="#ffffff" radius="32.0"/>
            <Label style="-fx-font-size: 26px;" text="🧑"/>
        </StackPane>

        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label fx:id="lbEleve" styleClass="result-name" text="—"/>
            <Label fx:id="lbInfos" styleClass="result-info"
                   text="Sélectionnez un élève puis cliquez sur Générer"/>
        </VBox>

        <VBox alignment="CENTER_RIGHT" spacing="6.0">
            <Label styleClass="result-label" text="MOYENNE GÉNÉRALE"/>
            <Label fx:id="lbMoyenne" styleClass="result-mark" text="—"/>
            <Label fx:id="lbMention" styleClass="result-mention" text=""/>
        </VBox>
    </HBox>

    <!-- Table -->
    <TableView fx:id="tvBulletin" styleClass="app-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colMatiere" prefWidth="320.0" text="Matière"/>
            <TableColumn fx:id="colNbNotes" prefWidth="130.0" text="Nb notes"/>
            <TableColumn fx:id="colMoyenne" prefWidth="170.0" text="Moyenne / 20"/>
            <TableColumn fx:id="colAppreciation" prefWidth="260.0" text="Appréciation"/>
        </columns>
    </TableView>

    <!-- ============= APPRÉCIATION IA (Gemini) ============= -->
    <VBox spacing="10.0" styleClass="pastel-purple">
        <padding><Insets bottom="18.0" left="20.0" right="20.0" top="16.0"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <HBox alignment="CENTER_LEFT" spacing="6.0" styleClass="card-tag">
                <Label text="✨"/>
                <Label styleClass="card-tag-text" text="Appréciation IA (Gemini)"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ProgressIndicator fx:id="aiSpinner" maxHeight="22.0" maxWidth="22.0" visible="false"/>
            <Button fx:id="btnGenererIA" onAction="#genererAppreciationIA"
                    prefHeight="38.0" styleClass="btn-primary" text="✨  Générer appréciation IA"/>
            <Button fx:id="btnRegenerer" onAction="#genererAppreciationIA"
                    prefHeight="38.0" styleClass="btn-secondary" text="↻  Régénérer" visible="false" managed="false"/>
        </HBox>

        <TextArea fx:id="taAppreciationIA" prefRowCount="4" wrapText="true"
                  promptText="Cliquer sur 'Générer appréciation IA' pour obtenir un commentaire personnalisé via Gemini."
                  styleClass="ai-textarea"/>
    </VBox>

    <!-- Footer -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label fx:id="lbDecision" styleClass="result-decision" text=""/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnImprimerPdf" onAction="#imprimerPdf"
                prefHeight="40.0" styleClass="btn-secondary"
                text="📄  Imprimer PDF"/>
        <Button fx:id="btnEnvoyerParents" onAction="#envoyerAuxParents"
                prefHeight="40.0" styleClass="btn-primary"
                text="📧  Envoyer aux parents"/>
    </HBox>
</VBox>
