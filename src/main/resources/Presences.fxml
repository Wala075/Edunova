<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.chart.PieChart?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.PresenceController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">

<VBox spacing="18">
    <padding><Insets top="10" right="4" bottom="20" left="0"/></padding>

    <!-- ===================== EN-TÊTE + FIL D'ARIANE ===================== -->
    <VBox spacing="4">
        <Label text="Gestion des présences"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Accueil  ›  Présences"
               style="-fx-font-size: 12; -fx-text-fill: #a8a8c0;"/>
    </VBox>

    <!-- ===================== 4 STAT CARDS ===================== -->
    <HBox spacing="14">

        <!-- Présents -->
        <VBox styleClass="stat-card" alignment="CENTER" spacing="6"
              style="-fx-background-color: linear-gradient(to bottom right, #10b981, #059669);
                     -fx-background-radius: 12; -fx-padding: 18;
                     -fx-effect: dropshadow(gaussian, rgba(16,185,129,0.3), 12, 0, 0, 4);"
              HBox.hgrow="ALWAYS">
            <Label text="Présents"
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"/>
            <Label fx:id="lblStatPresents" text="0"
                   style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <!-- Absents -->
        <VBox styleClass="stat-card" alignment="CENTER" spacing="6"
              style="-fx-background-color: linear-gradient(to bottom right, #ef4444, #dc2626);
                     -fx-background-radius: 12; -fx-padding: 18;
                     -fx-effect: dropshadow(gaussian, rgba(239,68,68,0.3), 12, 0, 0, 4);"
              HBox.hgrow="ALWAYS">
            <Label text="Absents"
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"/>
            <Label fx:id="lblStatAbsents" text="0"
                   style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <!-- Retards -->
        <VBox styleClass="stat-card" alignment="CENTER" spacing="6"
              style="-fx-background-color: linear-gradient(to bottom right, #f59e0b, #d97706);
                     -fx-background-radius: 12; -fx-padding: 18;
                     -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.3), 12, 0, 0, 4);"
              HBox.hgrow="ALWAYS">
            <Label text="Retards"
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"/>
            <Label fx:id="lblStatRetards" text="0"
                   style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

        <!-- Total -->
        <VBox styleClass="stat-card" alignment="CENTER" spacing="6"
              style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #4f46e5);
                     -fx-background-radius: 12; -fx-padding: 18;
                     -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.3), 12, 0, 0, 4);"
              HBox.hgrow="ALWAYS">
            <Label text="Total"
                   style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-weight: bold;"/>
            <Label fx:id="lblStatTotal" text="0"
                   style="-fx-font-size: 34; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>

    </HBox>

    <!-- ===================== BARRE FILTRES ===================== -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color: #1a1a2e; -fx-background-radius: 10; -fx-padding: 12;">
        <Label text="📅" style="-fx-font-size: 16;"/>
        <DatePicker fx:id="dpFilterDate" prefWidth="140"/>
        <Region prefWidth="10"/>
        <Label text="📚" style="-fx-font-size: 16;"/>
        <ComboBox fx:id="cbFilterSeance" prefWidth="240" promptText="Toutes les séances"/>
        <Region prefWidth="10"/>
        <Label text="📌" style="-fx-font-size: 16;"/>
        <ComboBox fx:id="cbFilterStatut" prefWidth="140" promptText="Tous statuts"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔍 Filtrer" styleClass="btn-primary"  onAction="#onFiltrer"/>
        <Button text="↻ Réinitialiser" styleClass="btn-secondary" onAction="#onResetFiltres"/>
    </HBox>

    <!-- ===================== ZONE PRINCIPALE : TABLE + QR ===================== -->
    <HBox spacing="14">

        <!-- =========== CARTES PRÉSENCES (gauche) =========== -->
        <VBox styleClass="card" spacing="10" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="📋 Liste des présences" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="tfSearch"
                           promptText="🔍 Rechercher..."
                           prefWidth="200" styleClass="search-field"
                           onAction="#onChercher"/>
                <Button text="📄 Export PDF" styleClass="btn-warning"   onAction="#onExportPDF"/>
                <Button text="📥 Export CSV" styleClass="btn-secondary" onAction="#onExportCSV"/>
            </HBox>

            <ScrollPane fitToWidth="true" prefHeight="380"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <FlowPane fx:id="cardsContainer" hgap="14" vgap="14"
                          style="-fx-padding: 4;"/>
            </ScrollPane>

            <!-- Actions sur la carte sélectionnée -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #0f0f1f; -fx-background-radius: 8; -fx-padding: 10;">
                <Label fx:id="lblActionInfo"
                       text="Cliquez sur une carte pour voir les actions"
                       style="-fx-font-size: 12; -fx-text-fill: #a8a8c0;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cbStatut" prefWidth="140"
                          promptText="Changer statut"/>
                <TextField fx:id="tfJustificatif"
                           promptText="Commentaire / justificatif"
                           prefWidth="240"/>
                <Button text="✔ Appliquer"  styleClass="btn-confirm"   onAction="#onModifier"/>
                <Button text="✘ Supprimer"  styleClass="btn-danger"    onAction="#onSupprimer"/>
                <Button text="↺"            styleClass="btn-secondary" onAction="#onReset"/>
            </HBox>
        </VBox>

        <!-- =========== PANNEAU QR CODE (droite) =========== -->
        <VBox styleClass="card" spacing="14" alignment="CENTER"
              style="-fx-min-width: 280; -fx-max-width: 280; -fx-padding: 20;">
            <Label text="📷 Scanner le QR Code"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Demandez aux étudiants de scanner ce QR Code pour marquer leur présence."
                   wrapText="true"
                   style="-fx-font-size: 11; -fx-text-fill: #a8a8c0; -fx-text-alignment: center;"/>

            <StackPane alignment="CENTER"
                       style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 14;">
                <ImageView fx:id="imgMiniQR" fitWidth="200" fitHeight="200" preserveRatio="true"/>
            </StackPane>

            <Label text="Code de la séance :"
                   style="-fx-font-size: 11; -fx-text-fill: #a8a8c0;"/>
            <Label fx:id="lblCodeSession" text="—"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #7c3aed;
                          -fx-font-family: 'Consolas';"/>

            <Button text="📷 Démarrer pointage"
                    onAction="#onPointageQR"
                    style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                           -fx-padding: 10 20; -fx-background-radius: 8;
                           -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 12;"
                    maxWidth="Infinity"/>

            <Label fx:id="lblSmsStatus" text=""
                   style="-fx-font-size: 11; -fx-text-fill: #a8a8c0; -fx-text-alignment: center;"
                   wrapText="true"/>
        </VBox>

    </HBox>

    <!-- ===================== FICHE ÉTUDIANT (existante) ===================== -->
    <VBox styleClass="card" spacing="14">
        <HBox spacing="14" alignment="CENTER_LEFT">
            <Label text="🎓 Fiche étudiant" styleClass="card-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Étudiant :" styleClass="field-label"/>
            <ComboBox fx:id="cbDetailStudent" prefWidth="260"
                      promptText="Choisir un étudiant..."/>
            <Button text="🔄" styleClass="btn-secondary" onAction="#onRafraichirDetail"/>
        </HBox>

        <Separator/>

        <Label fx:id="lblDetailNom" text="—"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <HBox spacing="20" alignment="CENTER"
              style="-fx-background-color: #1a1a2e; -fx-background-radius: 12; -fx-padding: 16;">
            <!-- Score & Taux -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="Taux de présence" style="-fx-font-size: 12; -fx-text-fill: #a8a8c0;"/>
                <StackPane fx:id="paneScorePill" alignment="CENTER"
                           style="-fx-background-color: #6b7280; -fx-background-radius: 30;
                                  -fx-min-width: 110; -fx-min-height: 42;
                                  -fx-max-width: 110; -fx-max-height: 42;">
                    <Label fx:id="lblDetailScore" text="— %"
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </StackPane>
            </VBox>
            
            <!-- PieChart de répartition -->
            <javafx.scene.chart.PieChart fx:id="pieDetailPresence" prefWidth="200" prefHeight="150" 
                      legendSide="RIGHT" style="-fx-background-color: transparent;"/>
        </HBox>
        
        <HBox alignment="CENTER" spacing="14" style="-fx-padding: 0 0 10 0;">
                <Label fx:id="lblDetailPresents"  text="0 présents"
                       style="-fx-font-size: 12; -fx-text-fill: #34d399;"/>
                <Label text="•" style="-fx-text-fill: #6b6b85;"/>
                <Label fx:id="lblDetailAbsents"   text="0 absents"
                       style="-fx-font-size: 12; -fx-text-fill: #f87171;"/>
                <Label text="•" style="-fx-text-fill: #6b6b85;"/>
                <Label fx:id="lblDetailRetards"   text="0 retards"
                       style="-fx-font-size: 12; -fx-text-fill: #fbbf24;"/>
                <Label text="•" style="-fx-text-fill: #6b6b85;"/>
                <Label fx:id="lblDetailJustifies" text="0 justifiés"
                       style="-fx-font-size: 12; -fx-text-fill: #a8a8c0;"/>
            </HBox>

        <Label text="Historique" styleClass="card-title"/>
        <TableView fx:id="tableDetail" prefHeight="200">
            <columns>
                <TableColumn fx:id="colDetailDate"     text="Date"             prefWidth="110"/>
                <TableColumn fx:id="colDetailContexte" text="Séance / Session" prefWidth="280"/>
                <TableColumn fx:id="colDetailStatut"   text="Statut"           prefWidth="170"/>
                <TableColumn fx:id="colDetailNote"     text="Taux"             prefWidth="80"/>
            </columns>
        </TableView>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="📱 Notifier le parent par SMS"
                    styleClass="btn-primary" onAction="#onEnvoyerSMSDetail"/>
        </HBox>
    </VBox>

</VBox>
</ScrollPane>
