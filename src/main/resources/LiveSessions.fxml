<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.LiveSessionController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;">

<VBox spacing="22">
    <padding><Insets top="10" right="4" bottom="30" left="0"/></padding>

    <!-- ===================== HEADER ===================== -->
    <HBox alignment="CENTER_LEFT" spacing="14">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Cours en ligne"
                   style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Accueil" style="-fx-font-size: 11; -fx-text-fill: #7c3aed; -fx-cursor: hand;"/>
                <Label text="›" style="-fx-font-size: 11; -fx-text-fill: #4a4a6a;"/>
                <Label text="Sessions Meet / Zoom" style="-fx-font-size: 11; -fx-text-fill: #a8a8c0;"/>
            </HBox>
        </VBox>
        <Button text="+ Nouvelle session"
                onAction="#onShowFormDialog"
                style="-fx-background-color: linear-gradient(to right, #06b6d4, #0891b2);
                       -fx-text-fill: white; -fx-padding: 12 24; -fx-background-radius: 10;
                       -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13;
                       -fx-effect: dropshadow(gaussian, rgba(6,182,212,0.4), 12, 0, 0, 3);"/>
    </HBox>

    <!-- ===================== 4 STAT CARDS ===================== -->
    <HBox spacing="16">

        <VBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
              style="-fx-background-color: rgba(99,102,241,0.08);
                     -fx-background-radius: 14; -fx-padding: 18 22;
                     -fx-border-color: rgba(99,102,241,0.25); -fx-border-radius: 14; -fx-border-width: 1;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-background-color: rgba(99,102,241,0.18);
                                   -fx-background-radius: 10;
                                   -fx-min-width: 40; -fx-min-height: 40;
                                   -fx-max-width: 40; -fx-max-height: 40;"
                           alignment="CENTER">
                    <Label text="📅" style="-fx-font-size: 18;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total sessions" style="-fx-font-size: 11; -fx-text-fill: #8a8aa3;"/>
                    <Label fx:id="lblStatTotal" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #818cf8;"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
              style="-fx-background-color: rgba(6,182,212,0.08);
                     -fx-background-radius: 14; -fx-padding: 18 22;
                     -fx-border-color: rgba(6,182,212,0.25); -fx-border-radius: 14; -fx-border-width: 1;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-background-color: rgba(6,182,212,0.18);
                                   -fx-background-radius: 10;
                                   -fx-min-width: 40; -fx-min-height: 40;
                                   -fx-max-width: 40; -fx-max-height: 40;"
                           alignment="CENTER">
                    <Label text="🟦" style="-fx-font-size: 18;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Programmées" style="-fx-font-size: 11; -fx-text-fill: #8a8aa3;"/>
                    <Label fx:id="lblStatProgrammees" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #22d3ee;"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
              style="-fx-background-color: rgba(239,68,68,0.08);
                     -fx-background-radius: 14; -fx-padding: 18 22;
                     -fx-border-color: rgba(239,68,68,0.25); -fx-border-radius: 14; -fx-border-width: 1;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-background-color: rgba(239,68,68,0.18);
                                   -fx-background-radius: 10;
                                   -fx-min-width: 40; -fx-min-height: 40;
                                   -fx-max-width: 40; -fx-max-height: 40;"
                           alignment="CENTER">
                    <Label text="🔴" style="-fx-font-size: 18;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="En cours" style="-fx-font-size: 11; -fx-text-fill: #8a8aa3;"/>
                    <Label fx:id="lblStatEnCours" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #f87171;"/>
                </VBox>
            </HBox>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS"
              style="-fx-background-color: rgba(16,185,129,0.08);
                     -fx-background-radius: 14; -fx-padding: 18 22;
                     -fx-border-color: rgba(16,185,129,0.25); -fx-border-radius: 14; -fx-border-width: 1;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane style="-fx-background-color: rgba(16,185,129,0.18);
                                   -fx-background-radius: 10;
                                   -fx-min-width: 40; -fx-min-height: 40;
                                   -fx-max-width: 40; -fx-max-height: 40;"
                           alignment="CENTER">
                    <Label text="✅" style="-fx-font-size: 18;"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Terminées" style="-fx-font-size: 11; -fx-text-fill: #8a8aa3;"/>
                    <Label fx:id="lblStatTerminees" text="0"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #34d399;"/>
                </VBox>
            </HBox>
        </VBox>

    </HBox>

    <!-- ===================== TABS + RECHERCHE ===================== -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: rgba(26,26,46,0.6);
                 -fx-background-radius: 12; -fx-padding: 12 16;
                 -fx-border-color: rgba(42,42,61,0.6); -fx-border-radius: 12; -fx-border-width: 1;">
        <TabPane fx:id="tabFilter" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS">
            <tabs>
                <Tab text="  Toutes  "/>
                <Tab text="  Programmées  "/>
                <Tab text="  En cours  "/>
                <Tab text="  Terminées  "/>
            </tabs>
        </TabPane>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="tfSearch" promptText="🔍 Rechercher une session..."
                   prefWidth="280" styleClass="search-field"
                   onAction="#onChercher"/>
    </HBox>

    <!-- ===================== GRILLE DE CARTES ===================== -->
    <FlowPane fx:id="cardsContainer" hgap="16" vgap="16" prefWrapLength="900"/>

    <Label fx:id="lblEmpty" text="📭 Aucune session live. Cliquez sur '+ Nouvelle session' pour commencer."
           style="-fx-font-size: 14; -fx-text-fill: #a8a8c0; -fx-padding: 30; -fx-text-alignment: center;"
           visible="false"/>

</VBox>
</ScrollPane>
