<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="980.0"
            styleClass="pro-page-root" stylesheets="@dashboard.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AjouterNote">

    <!-- ============= Header ============= -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="pro-page-header">
            <Button onAction="#retour" styleClass="pro-back-btn" text="◀"/>
            <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                <Label styleClass="pro-page-title-big" text="Ajouter une note"/>
                <Label styleClass="pro-page-sub-big"
                       text="Saisir une nouvelle évaluation pour un élève"/>
            </VBox>
        </HBox>
    </top>

    <!-- ============= Content ============= -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="pro-page-content">
            <VBox spacing="20" style="-fx-padding: 28 36 24 36;">

                <!-- Card form -->
                <VBox spacing="20" styleClass="pro-card-block">

                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="pro-block-title" text="📝  Détails de l'évaluation"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label styleClass="pro-pill" text="Nouvelle saisie"/>
                    </HBox>

                    <!-- Row 1 : Classe -->
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="CLASSE"/>
                            <ComboBox fx:id="cbClasse" maxWidth="1.7976931348623157E308"
                                      prefHeight="40" promptText="Sélectionner une classe"
                                      styleClass="pro-combo"/>
                        </VBox>
                    </HBox>

                    <!-- Row 2 : Élève + Matière -->
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="ÉLÈVE"/>
                            <ComboBox fx:id="cbEleve" maxWidth="1.7976931348623157E308"
                                      prefHeight="40" promptText="Sélectionner un élève"
                                      styleClass="pro-combo"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="MATIÈRE"/>
                            <ComboBox fx:id="cbMatiere" maxWidth="1.7976931348623157E308"
                                      prefHeight="40" promptText="Sélectionner une matière"
                                      styleClass="pro-combo"/>
                        </VBox>
                    </HBox>

                    <!-- Row 3 : Note + Coef + Trimestre -->
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="NOTE  / 20"/>
                            <TextField fx:id="tfValeur" prefHeight="40"
                                       promptText="0 - 20" styleClass="pro-input"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="COEFFICIENT"/>
                            <TextField fx:id="tfCoefficient" prefHeight="40"
                                       text="1" styleClass="pro-input"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="TRIMESTRE"/>
                            <ComboBox fx:id="cbTrimestre" maxWidth="1.7976931348623157E308"
                                      prefHeight="40" promptText="Trimestre"
                                      styleClass="pro-combo"/>
                        </VBox>
                    </HBox>

                    <!-- Row 4 : Type + Date + Année -->
                    <HBox spacing="14">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="TYPE D'ÉVALUATION"/>
                            <ComboBox fx:id="cbType" maxWidth="1.7976931348623157E308"
                                      prefHeight="40" promptText="Type"
                                      styleClass="pro-combo"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="DATE"/>
                            <DatePicker fx:id="dpDate" maxWidth="1.7976931348623157E308"
                                        prefHeight="40" styleClass="pro-date-picker"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="pro-label" text="ANNÉE SCOLAIRE"/>
                            <TextField fx:id="tfAnnee" prefHeight="40"
                                       text="2024-2025" styleClass="pro-input"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Region prefHeight="20"/>
            </VBox>
        </ScrollPane>
    </center>

    <!-- ============= Footer (actions) ============= -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #16162e; -fx-padding: 16 32; -fx-border-color: #2d2d4e; -fx-border-width: 1 0 0 0;">
            <Button onAction="#voirListe" styleClass="pro-btn-secondary"
                    text="📋  Voir la liste"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#annuler" styleClass="pro-btn-secondary" text="Annuler"/>
            <Button onAction="#ajouterNote" styleClass="pro-btn-primary"
                    text="✓  Ajouter la note"/>
        </HBox>
    </bottom>
</BorderPane>
