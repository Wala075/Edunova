<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" prefHeight="700" prefWidth="1100"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.MainController"
            style="-fx-background-color: #0f0f1f;">

    <!-- ══════════════ SIDEBAR ══════════════ -->
    <left>
        <VBox fx:id="sidebar" prefWidth="260"
              style="-fx-background-color: #1a1a2e;">

            <!-- Logo -->
            <VBox fx:id="logoBox" alignment="CENTER" style="-fx-padding: 25 20 20 20;">
                <Label fx:id="lblLogo"
                       style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #7c3aed;"
                       text="EduNova" />
                <Label fx:id="lblLogoSub"
                       style="-fx-font-size: 10; -fx-text-fill: #a78bfa; -fx-wrap-text: true; -fx-text-alignment: center;"
                       text="Application de gestion scolaire" />
            </VBox>

            <Region fx:id="sepLogo" style="-fx-background-color: #2d2d4e; -fx-pref-height: 1;" />

            <!-- Avatar utilisateur -->
            <VBox fx:id="userBox" alignment="CENTER" style="-fx-padding: 18 15;">
                <StackPane fx:id="avatarPane" alignment="CENTER"
                           style="-fx-background-color: #7c3aed; -fx-background-radius: 50;
                                  -fx-min-width: 60; -fx-min-height: 60;
                                  -fx-max-width: 60; -fx-max-height: 60;">
                    <Label fx:id="lblAvatarInitiales"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white;"
                           text="A" />
                </StackPane>
                <Label fx:id="lblUserNom"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-padding: 8 0 2 0; -fx-text-fill: white;"
                       text="admin@edunova.com" />
                <Label fx:id="lblUserRole"
                       style="-fx-font-size: 11; -fx-background-color: #2d1b69; -fx-text-fill: #a78bfa;
                              -fx-background-radius: 10; -fx-padding: 3 10;"
                       text="Administrateur" />
            </VBox>

            <Region fx:id="sepUser" style="-fx-background-color: #2d2d4e; -fx-pref-height: 1;" />

            <!-- Menu de navigation -->
            <VBox fx:id="menuBox" spacing="4" style="-fx-padding: 15 12;">
                <Button fx:id="btnMenuDashboard" maxWidth="Infinity"
                        onAction="#openDashboard"
                        style="-fx-background-color: #7c3aed; -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   Tableau de bord" />

                <Button fx:id="btnMenuLive" maxWidth="Infinity"
                        onAction="#openLiveSessions"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8a8c0;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   Cours en ligne" />

                <Button fx:id="btnMenuPresences" maxWidth="Infinity"
                        onAction="#openPresences"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8a8c0;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   Présences" />

                <Button fx:id="btnMenuCoursTeacher" maxWidth="Infinity"
                        onAction="#openCoursTeacher"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8a8c0;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   📚 Cours (Enseignant)" />

                <Button fx:id="btnMenuCoursStudent" maxWidth="Infinity"
                        onAction="#openCoursStudent"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8a8c0;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   🎓 Cours (Étudiant)" />

                <Button fx:id="btnMenuQuizTeacher" maxWidth="Infinity"
                        onAction="#openQuizTeacher"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8a8c0;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   📝 Quiz (Enseignant)" />

                <Button fx:id="btnMenuQuizStudent" maxWidth="Infinity"
                        onAction="#openQuizStudent"
                        style="-fx-background-color: transparent; -fx-text-fill: #a8a8c0;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER_LEFT;
                               -fx-cursor: hand; -fx-font-size: 13;"
                        text="   🧠 Quiz (Étudiant)" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <!-- Bottom : theme toggle + logout -->
            <VBox fx:id="bottomBox" spacing="8" style="-fx-padding: 12 12 20 12;">
                <HBox alignment="CENTER" spacing="10">
                    <Label fx:id="lblTheme" style="-fx-font-size: 12; -fx-text-fill: #a8a8c0;" text="  Mode sombre">
                        <font><Font size="14.0" /></font>
                    </Label>
                    <Button fx:id="btnToggleTheme" onAction="#toggleTheme"
                            prefHeight="27.0" prefWidth="96.0"
                            style="-fx-background-color: #7c3aed; -fx-text-fill: white;
                                   -fx-background-radius: 20; -fx-padding: 5 16; -fx-font-size: 12; -fx-cursor: hand;"
                            text=" Light">
                        <font><Font size="13.0" /></font>
                    </Button>
                </HBox>
                <Button fx:id="btnDeconnexion" maxWidth="Infinity"
                        onAction="#logout"
                        style="-fx-background-color: #2d1b1b; -fx-text-fill: #f87171; -fx-font-size: 13;
                               -fx-background-radius: 8; -fx-padding: 11 15; -fx-alignment: CENTER; -fx-cursor: hand;"
                        text="Déconnexion">
                    <font><Font size="13.0" /></font>
                </Button>
            </VBox>
        </VBox>
    </left>

    <!-- ══════════════ CONTENU PRINCIPAL ══════════════ -->
    <center>
        <VBox fx:id="mainContent" style="-fx-background-color: #0f0f1f;">

            <!-- NAVBAR -->
            <HBox fx:id="navbar" alignment="CENTER_LEFT" style="-fx-padding: 15 25;">
                <VBox>
                    <Label fx:id="lblPageTitre"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"
                           text="Tableau de bord" />
                    <Label fx:id="lblPageSousTitre"
                           style="-fx-font-size: 12; -fx-text-fill: #a8a8c0;"
                           text="Vue d'ensemble" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtRechercheGlobal" prefWidth="220" promptText="  Rechercher..."
                           style="-fx-background-color: #1a1a2e; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #6b6b85; -fx-background-radius: 20;
                                  -fx-padding: 8 16; -fx-border-color: #2d2d4e; -fx-border-radius: 20;" />
                <Label fx:id="lblDateHeure"
                       style="-fx-font-size: 12; -fx-padding: 0 0 0 20; -fx-text-fill: #a8a8c0;" />
            </HBox>

            <Region fx:id="sepNavbar" style="-fx-pref-height: 1; -fx-background-color: #2d2d4e;" />

            <!-- Container des pages -->
            <StackPane fx:id="pageContainer" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: #0f0f1f; -fx-padding: 25;" />

        </VBox>
    </center>
</BorderPane>
