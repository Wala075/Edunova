# ============================================
# EduNova - Configuration des API externes
# ============================================
# Copier ce fichier en .env et remplir les vraies valeurs.
# Le fichier .env est dans .gitignore (ne JAMAIS commit).

# --- Gemini AI (Google AI Studio) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_remplace_par_ta_cle
# Optionnel — modèle Gemini (par défaut: gemini-2.5-flash)
# Autres options : gemini-2.5-pro, gemini-2.0-flash, gemini-flash-latest
#GEMINI_MODEL=gemini-2.5-flash

# --- Brevo (ex-Sendinblue) ---
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-remplace_par_ta_cle
BREVO_SENDER_EMAIL=no-reply@edunova.tn
BREVO_SENDER_NAME=EduNova

# --- Twilio SMS ---
# https://console.twilio.com/
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=remplace_par_ton_auth_token
TWILIO_FROM=+1234567890
