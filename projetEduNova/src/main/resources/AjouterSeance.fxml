<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.edunova.controllers.AjouterSeance"
            fitToWidth="true" hbarPolicy="NEVER"
            stylesheets="@dashboard.css" styleClass="center-scroll">

    <VBox spacing="18" styleClass="app-root">
        <padding><Insets bottom="28" left="28" right="28" top="28"/></padding>

        <!-- En-tête + navigation semaine -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="page-icon-badge" text="📅"/>
                    <Label styleClass="app-title" text="Emploi du Temps"/>
                </HBox>
                <Label fx:id="weekRangeLabel" styleClass="app-subtitle" text="Semaine en cours..."/>
            </VBox>
            <Button text="◀  Précédente" onAction="#semainePrecedente" prefHeight="38" styleClass="btn-ghost"/>
            <Button text="Aujourd'hui"   onAction="#semaineActuelle"   prefHeight="38" styleClass="btn-secondary"/>
            <Button text="Suivante  ▶"  onAction="#semaineSuivante"   prefHeight="38" styleClass="btn-ghost"/>
            <Button text="⬇  PDF"       onAction="#exporterPDF"       prefHeight="38" styleClass="btn-primary"/>
        </HBox>

        <!-- Filtres -->
        <VBox spacing="10" styleClass="form-panel">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="classTitleLabel" styleClass="panel-section-title" text="Classe : —"/>
                <Label fx:id="resultatLabel" styleClass="section-head-sub" text=""/>
                <Region HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="filtreClasseCombo" prefHeight="38" prefWidth="170"
                          promptText="Filtrer par classe" styleClass="combo-pill"/>
                <ComboBox fx:id="filtreTeacherCombo" prefHeight="38" prefWidth="190"
                          promptText="Filtrer par enseignant" styleClass="combo-pill"/>
            </HBox>
        </VBox>

        <!-- Grille emploi du temps -->
        <VBox spacing="0" styleClass="timetable-wrapper" VBox.vgrow="ALWAYS">
            <ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" styleClass="center-scroll" VBox.vgrow="ALWAYS">
                <GridPane fx:id="timetableGrid" hgap="0" vgap="0" styleClass="tt-printed-grid">
                    <padding><Insets top="0" right="0" bottom="0" left="0"/></padding>
                </GridPane>
            </ScrollPane>
        </VBox>

    </VBox>
</ScrollPane>
