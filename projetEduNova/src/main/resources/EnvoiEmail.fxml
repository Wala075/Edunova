<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.edunova.controllers.EnvoiEmail"
            fitToWidth="true" hbarPolicy="NEVER"
            stylesheets="@dashboard.css" styleClass="center-scroll">

    <VBox spacing="22" styleClass="app-root">
        <padding><Insets bottom="28" left="28" right="28" top="28"/></padding>

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="page-icon-badge" text="✉"/>
                    <Label styleClass="app-title" text="Envoi de l'emploi du temps"/>
                </HBox>
                <Label styleClass="app-subtitle"
                       text="Envoyez l'emploi du temps par email aux parents enregistrés"/>
            </VBox>
            <Label fx:id="resultatLabel" styleClass="section-head-sub" text=""/>
        </HBox>

        <!-- Filtres & Recherche -->
        <VBox spacing="14" styleClass="form-panel">
            <Label styleClass="panel-section-title" text="Recherche et filtres"/>

            <HBox alignment="BOTTOM_LEFT" spacing="14">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-form" text="RECHERCHE (NOM, PRÉNOM, EMAIL)"/>
                    <TextField fx:id="searchField" prefHeight="40"
                               promptText="Taper un nom, prénom ou email..." styleClass="input-pill"/>
                </VBox>
                <VBox spacing="6">
                    <Label styleClass="label-form" text="FILTRER PAR CLASSE"/>
                    <ComboBox fx:id="filtreClasseCombo" prefHeight="40" prefWidth="210"
                              promptText="Toutes les classes" styleClass="combo-pill"/>
                </VBox>
            </HBox>

            <!-- Boutons d'envoi -->
            <HBox spacing="12" style="-fx-padding: 4 0 0 0;">
                <Button text="📤  Envoyer au parent sélectionné" onAction="#envoyerEmail"
                        prefHeight="42" styleClass="btn-primary"/>
                <Button text="📨  Envoyer à toute la classe" onAction="#envoyerATous"
                        prefHeight="42" styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <!-- Table parents -->
        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="section-head" text="Liste des parents"/>
            </HBox>

            <TableView fx:id="parentsTable" prefHeight="400" styleClass="app-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNom"    prefWidth="240" text="Nom complet"/>
                    <TableColumn fx:id="colEmail"  prefWidth="300" text="Adresse email"/>
                    <TableColumn fx:id="colClasse" prefWidth="200" text="Classe de l'enfant"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>
