<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.edunova.controllers.AjouterClasse"
            fitToWidth="true" hbarPolicy="NEVER"
            stylesheets="@dashboard.css" styleClass="center-scroll">

    <VBox spacing="22" styleClass="app-root">
        <padding><Insets bottom="28" left="28" right="28" top="28"/></padding>

        <!-- En-tête page -->
        <HBox alignment="CENTER_LEFT" spacing="14">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="page-icon-badge" text="🏫"/>
                    <Label styleClass="app-title" text="Gestion des Classes"/>
                </HBox>
                <Label styleClass="app-subtitle" text="Ajouter, modifier ou supprimer une classe scolaire"/>
            </VBox>
        </HBox>

        <!-- Sélection classe existante -->
        <VBox spacing="10" styleClass="form-panel">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="panel-section-title" text="Sélectionner une classe existante"/>
                <Label styleClass="panel-section-hint" text="(pour modifier ou supprimer)"/>
            </HBox>
            <ComboBox fx:id="selectionCombo" maxWidth="1.7976931348623157E308" prefHeight="40"
                      promptText="Choisir une classe dans la liste..." styleClass="combo-pill"/>
        </VBox>

        <!-- Formulaire -->
        <VBox spacing="18" styleClass="form-panel">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label styleClass="panel-section-title" text="Informations de la classe"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Vider le formulaire" onAction="#viderForm" styleClass="btn-ghost"/>
            </HBox>

            <!-- Ligne 1 : Nom + Niveau + Capacité -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-form" text="NOM DE LA CLASSE *"/>
                    <TextField fx:id="nomField" prefHeight="40" promptText="Ex : 6A, Terminale S..." styleClass="input-pill">
                        <tooltip><Tooltip text="Nom unique de la classe (2-20 caractères)"/></tooltip>
                    </TextField>
                    <Label fx:id="nomError" styleClass="form-error" text=""/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-form" text="NIVEAU *"/>
                    <ComboBox fx:id="niveauCombo" maxWidth="1.7976931348623157E308" prefHeight="40"
                              promptText="Sélectionner un niveau" styleClass="combo-pill"/>
                    <Label fx:id="niveauError" styleClass="form-error" text=""/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label styleClass="label-form" text="CAPACITÉ (élèves) *"/>
                    <TextField fx:id="capaciteField" prefHeight="40" promptText="Ex : 30" styleClass="input-pill"/>
                    <Label fx:id="capaciteError" styleClass="form-error" text=""/>
                </VBox>
            </HBox>

            <!-- Actions -->
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 6 0 0 0;">
                <Button text="＋  Ajouter" onAction="#ajouterClasse" styleClass="btn-primary" prefHeight="40"/>
                <Button text="✎  Modifier" onAction="#modifierClasse" styleClass="btn-secondary" prefHeight="40"/>
                <Button text="🗑  Supprimer" onAction="#supprimerClasse" styleClass="btn-danger" prefHeight="40"/>
            </HBox>
        </VBox>

    </VBox>
</ScrollPane>
