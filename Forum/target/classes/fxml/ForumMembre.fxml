<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane minWidth="900.0" minHeight="640.0"
            style="-fx-background-color:#f0f2f5;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ForumMembreController">

    <!-- ═══════════════════════════════════════════════
         SIDEBAR GAUCHE
    ═══════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="230.0" spacing="0.0"
              style="-fx-background-color:white;-fx-border-color:#e5e7eb;-fx-border-width:0 1 0 0;">

            <!-- Logo -->
            <VBox alignment="CENTER" spacing="4.0" style="-fx-padding:24 16 16 16;">
                <Label style="-fx-font-size:24px;-fx-font-weight:900;-fx-text-fill:#7c3aed;" text="EduNova"/>
                <Label style="-fx-font-size:11px;-fx-text-fill:#9ca3af;" text="Application de gestion scolaire"/>
            </VBox>

            <!-- Profil -->
            <VBox alignment="CENTER" spacing="8.0"
                  style="-fx-background-color:#f5f3ff;-fx-padding:16 12;">
                <Label fx:id="lbInitiales"
                       style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-weight:700;-fx-font-size:18px;-fx-background-radius:50%;-fx-min-width:52px;-fx-min-height:52px;-fx-pref-width:52px;-fx-pref-height:52px;-fx-alignment:center;"
                       text="?"/>
                <Label fx:id="lbNomUser"
                       style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#1f2937;" text="Utilisateur"/>
                <Label fx:id="lbRoleUser"
                       style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-size:10px;-fx-font-weight:600;-fx-background-radius:20px;-fx-padding:3 10;"
                       text="Membre"/>
                <HBox alignment="CENTER" spacing="4.0">
                    <Label style="-fx-font-size:11px;-fx-text-fill:#9ca3af;" text="Posts :"/>
                    <Label fx:id="lbNbMesPosts"
                           style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:#7c3aed;" text="0 posts"/>
                </HBox>
                <Label fx:id="lbBadgeReputation"
                       style="-fx-background-color:#6b7280;-fx-text-fill:white;-fx-font-size:11px;-fx-font-weight:700;-fx-background-radius:20px;-fx-padding:3 12;"
                       text="🌱 Débutant"/>
                <Label fx:id="lbPointsReputation"
                       style="-fx-font-size:10px;-fx-text-fill:#9ca3af;" text="0 pts"/>
            </VBox>

            <Separator/>

            <!-- Navigation -->
            <Button maxWidth="1.7976931348623157E308" prefHeight="40.0"
                    style="-fx-background-color:transparent;-fx-text-fill:#374151;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;"
                    text="📋  Tableau de bord"/>
            <Button maxWidth="1.7976931348623157E308" prefHeight="40.0"
                    style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-weight:700;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;"
                    text="💬  Forum"/>
            <Button maxWidth="1.7976931348623157E308" prefHeight="40.0"
                    style="-fx-background-color:transparent;-fx-text-fill:#374151;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;"
                    text="📅  Emploi du temps"/>
            <Button maxWidth="1.7976931348623157E308" prefHeight="40.0"
                    style="-fx-background-color:transparent;-fx-text-fill:#374151;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;"
                    text="📊  Notes"/>

            <Separator/>

            <!-- Mes publications -->
            <VBox spacing="6.0" style="-fx-padding:14 12 10 12;">
                <Label style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:#374151;" text="📋  Mes publications"/>
                <Label style="-fx-font-size:9px;-fx-text-fill:#9ca3af;" text="✅ Approuvé  ⏳ En attente  ❌ Rejeté"/>
                <ScrollPane fitToWidth="true" prefHeight="180.0"
                            style="-fx-background-color:transparent;-fx-background:transparent;-fx-border-color:transparent;">
                    <VBox fx:id="vbMesPosts" spacing="4.0"/>
                </ScrollPane>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>

            <!-- Notifications -->
            <HBox alignment="CENTER_LEFT" spacing="0.0"
                  style="-fx-padding:0;-fx-min-height:40px;">
                <Button onAction="#ouvrirNotifications" maxWidth="1.7976931348623157E308"
                        HBox.hgrow="ALWAYS"
                        style="-fx-background-color:transparent;-fx-text-fill:#374151;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;-fx-pref-height:40px;"
                        text="🔔  Notifications"/>
                <Label fx:id="lbBadge"
                       style="-fx-background-color:#ef4444;-fx-text-fill:white;-fx-font-size:9px;-fx-font-weight:700;-fx-background-radius:50%;-fx-min-width:18px;-fx-min-height:18px;-fx-pref-width:18px;-fx-pref-height:18px;-fx-alignment:center;"
                       text="0" visible="false" managed="false"/>
                <Region style="-fx-pref-width:10px;"/>
            </HBox>

            <!-- Mode sombre -->
            <Button fx:id="btnTheme" maxWidth="1.7976931348623157E308"
                    onAction="#toggleTheme" prefHeight="40.0"
                    style="-fx-background-color:transparent;-fx-text-fill:#6b7280;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;"
                    text="🌙  Mode sombre"/>

            <!-- Déconnexion -->
            <Button maxWidth="1.7976931348623157E308"
                    onAction="#seDeconnecter" prefHeight="40.0"
                    style="-fx-background-color:transparent;-fx-text-fill:#ef4444;-fx-font-size:13px;-fx-alignment:CENTER_LEFT;-fx-padding:0 0 0 16;-fx-background-radius:0;-fx-cursor:hand;"
                    text="🚪  Déconnexion"/>
            <Region style="-fx-pref-height:8px;"/>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════
         CENTRE — Nouveau post + Fil de posts
    ═══════════════════════════════════════════════ -->
    <center>
        <VBox spacing="0.0" style="-fx-padding:20 60 20 60;" VBox.vgrow="ALWAYS">

            <!-- Barre recherche -->
            <HBox alignment="CENTER_LEFT" spacing="8.0"
                  style="-fx-background-color:white;-fx-background-radius:12px;-fx-border-color:#e5e7eb;-fx-border-radius:12px;-fx-border-width:1px;-fx-padding:8 14;">
                <Label style="-fx-font-size:14px;" text="🔍"/>
                <TextField fx:id="tfRecherche" prefHeight="32.0"
                           promptText="Rechercher dans le forum…"
                           style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-font-size:13px;"
                           HBox.hgrow="ALWAYS"/>
                <Button onAction="#rechercher" prefHeight="32.0"
                        style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:600;-fx-background-radius:8px;-fx-cursor:hand;-fx-padding:4 14;"
                        text="Rechercher"/>
                <Button onAction="#resetRecherche" prefHeight="32.0"
                        style="-fx-background-color:#f3f4f6;-fx-text-fill:#6b7280;-fx-background-radius:8px;-fx-cursor:hand;-fx-padding:4 10;"
                        text="Tout voir"/>
            </HBox>

            <Region style="-fx-pref-height:14px;"/>

            <!-- ── Formulaire nouveau post (style Facebook) ── -->
            <VBox fx:id="panelNouveauPost" spacing="10.0"
                  style="-fx-background-color:white;-fx-background-radius:12px;-fx-border-color:#e5e7eb;-fx-border-radius:12px;-fx-border-width:1px;-fx-padding:14 16 12 16;">

                <!-- Ligne avatar + champ titre cliquable -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label fx:id="lbInitialesPost"
                           style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-weight:700;-fx-font-size:15px;-fx-background-radius:50%;-fx-min-width:40px;-fx-min-height:40px;-fx-pref-width:40px;-fx-pref-height:40px;-fx-alignment:center;"
                           text="?"/>
                    <TextField fx:id="tfTitre" prefHeight="38.0"
                               promptText="Titre de votre post…"
                               style="-fx-background-color:#f0f2f5;-fx-border-color:transparent;-fx-background-radius:20px;-fx-font-size:13px;-fx-padding:6 14;"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Zone contenu (cachée par défaut, s'ouvre au clic) -->
                <VBox fx:id="panelContenu" managed="false" visible="false" spacing="8.0">
                    <TextArea fx:id="taContenu" prefHeight="80.0"
                              promptText="Partagez vos pensées, questions…"
                              wrapText="true"
                              style="-fx-background-color:#f9fafb;-fx-border-color:#e5e7eb;-fx-border-radius:8px;-fx-background-radius:8px;-fx-font-size:13px;"/>

                    <!-- Photo -->
                    <HBox spacing="6.0" alignment="CENTER_LEFT">
                        <Label style="-fx-font-size:11px;-fx-text-fill:#6b7280;" text="📎 Photo (optionnel) :"/>
                        <TextField fx:id="tfPhotoPath" prefHeight="28.0" promptText="Aucune image…"
                                   style="-fx-background-color:#f9fafb;-fx-border-color:#e5e7eb;-fx-border-radius:8px;-fx-background-radius:8px;-fx-font-size:11px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button onAction="#choisirPhoto" prefHeight="28.0" prefWidth="28.0"
                                style="-fx-background-color:#f3f4f6;-fx-font-size:13px;-fx-background-radius:8px;-fx-cursor:hand;-fx-border-color:transparent;"
                                text="🖼"/>
                    </HBox>

                    <Label fx:id="lbFeedback" style="-fx-font-size:11px;-fx-wrap-text:true;" text=""/>

                    <HBox spacing="8.0" alignment="CENTER_RIGHT">
                        <Button onAction="#annulerPost" prefHeight="32.0"
                                style="-fx-background-color:transparent;-fx-text-fill:#6b7280;-fx-font-size:12px;-fx-border-color:#e5e7eb;-fx-border-width:1px;-fx-border-radius:8px;-fx-background-radius:8px;-fx-cursor:hand;-fx-padding:4 14;"
                                text="Annuler"/>
                        <Button onAction="#publier" prefHeight="32.0"
                                style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-weight:700;-fx-font-size:13px;-fx-background-radius:8px;-fx-cursor:hand;-fx-padding:4 20;"
                                text="📤 Publier"/>
                    </HBox>
                </VBox>

                <Separator/>

                <!-- Bouton raccourci "Quoi de neuf ?" -->
                <HBox spacing="12.0" alignment="CENTER">
                    <Button onAction="#ouvrirFormulairePost" maxWidth="1.7976931348623157E308"
                            HBox.hgrow="ALWAYS"
                            style="-fx-background-color:transparent;-fx-text-fill:#65676b;-fx-font-size:13px;-fx-cursor:hand;-fx-border-color:transparent;-fx-alignment:CENTER_LEFT;"
                            text="📝  Quoi de neuf ?"/>
                    <Button onAction="#choisirPhoto"
                            style="-fx-background-color:transparent;-fx-text-fill:#45bd62;-fx-font-size:12px;-fx-cursor:hand;-fx-border-color:transparent;"
                            text="🖼 Photo"/>
                </HBox>
            </VBox>

            <Region style="-fx-pref-height:14px;"/>

            <!-- Fil scrollable -->
            <ScrollPane fx:id="spFil" fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                <VBox fx:id="vbFil" spacing="14.0" style="-fx-padding:0 0 12 0;"/>
            </ScrollPane>
        </VBox>
    </center>

    <!-- ═══════════════════════════════════════════════
         SIDEBAR DROITE — Utilisateurs en ligne + Chat
    ═══════════════════════════════════════════════ -->
    <right>
        <VBox prefWidth="220.0" spacing="0.0"
              style="-fx-background-color:white;-fx-border-color:#e5e7eb;-fx-border-width:0 0 0 1;">

            <!-- Header -->
            <VBox spacing="2.0" style="-fx-padding:16 14 10 14;">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
                    <Label style="-fx-font-size:13px;-fx-font-weight:700;-fx-text-fill:#1f2937;"
                           text="Contacts"/>
                    <Label fx:id="lbChatUnread"
                           style="-fx-background-color:#ef4444;-fx-text-fill:white;-fx-font-size:9px;-fx-font-weight:700;-fx-background-radius:50%;-fx-min-width:16px;-fx-min-height:16px;-fx-pref-width:16px;-fx-pref-height:16px;-fx-alignment:center;"
                           text="0" visible="false" managed="false"/>
                </HBox>
                <Label style="-fx-font-size:10px;-fx-text-fill:#9ca3af;"
                       text="Cliquez pour ouvrir un chat"/>
            </VBox>

            <Separator/>

            <!-- Liste des utilisateurs -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background:transparent;-fx-background-color:transparent;-fx-border-color:transparent;">
                <VBox fx:id="vbContacts" spacing="0.0"/>
            </ScrollPane>

        </VBox>
    </right>

</BorderPane>
