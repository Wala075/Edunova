<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="560.0" prefWidth="420.0" spacing="0.0"
      style="-fx-background-color:#f5f3ff;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.LoginController">

    <!-- Carte centrale -->
    <VBox alignment="CENTER" spacing="20.0"
          style="-fx-background-color:white;-fx-background-radius:20px;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.12),20,0,0,4);">
        <padding><Insets bottom="36.0" left="40.0" right="40.0" top="36.0"/></padding>

        <!-- Logo -->
        <VBox alignment="CENTER" spacing="4.0">
            <Label style="-fx-font-size:32px;-fx-font-weight:900;-fx-text-fill:#7c3aed;" text="EduNova"/>
            <Label style="-fx-font-size:12px;-fx-text-fill:#9ca3af;" text="Application de gestion scolaire"/>
        </VBox>

        <!-- Titre -->
        <Label style="-fx-font-size:18px;-fx-font-weight:700;-fx-text-fill:#1f2937;" text="Connexion au Forum"/>

        <!-- Champs -->
        <VBox spacing="8.0">
            <Label style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:#6b7280;" text="EMAIL / NOM D'UTILISATEUR"/>
            <TextField fx:id="tfUsername" prefHeight="42.0"
                       promptText="votre@email.com"
                       style="-fx-background-color:#f9fafb;-fx-background-radius:10px;-fx-border-color:#e5e7eb;-fx-border-radius:10px;-fx-border-width:1px;-fx-font-size:13px;-fx-padding:8 14 8 14;"/>
        </VBox>
        <VBox spacing="8.0">
            <Label style="-fx-font-size:11px;-fx-font-weight:700;-fx-text-fill:#6b7280;" text="MOT DE PASSE"/>
            <PasswordField fx:id="pfPassword" prefHeight="42.0"
                           promptText="••••••••"
                           style="-fx-background-color:#f9fafb;-fx-background-radius:10px;-fx-border-color:#e5e7eb;-fx-border-radius:10px;-fx-border-width:1px;-fx-font-size:13px;-fx-padding:8 14 8 14;"/>
        </VBox>

        <!-- Erreur -->
        <Label fx:id="lbErreur" text="" style="-fx-text-fill:#ef4444;-fx-font-size:12px;"/>

        <!-- Bouton connexion -->
        <Button maxWidth="1.7976931348623157E308" onAction="#seConnecter" prefHeight="44.0"
                style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-font-weight:700;-fx-font-size:14px;-fx-background-radius:12px;-fx-cursor:hand;"
                text="Se connecter"/>

        <Separator/>

        <!-- Comptes de test -->
        <VBox spacing="8.0" alignment="CENTER">
            <Label style="-fx-font-size:11px;-fx-text-fill:#9ca3af;-fx-font-weight:600;" text="COMPTES DE TEST RAPIDE"/>
            <HBox spacing="8.0" alignment="CENTER">
                <Button fx:id="btnAdmin" prefHeight="34.0" prefWidth="100.0"
                        style="-fx-background-color:#7c3aed;-fx-text-fill:white;-fx-background-radius:20px;-fx-font-size:11px;-fx-font-weight:600;-fx-cursor:hand;"
                        text="🛡 Admin"/>
                <Button fx:id="btnEtudiant" prefHeight="34.0" prefWidth="100.0"
                        style="-fx-background-color:#2563eb;-fx-text-fill:white;-fx-background-radius:20px;-fx-font-size:11px;-fx-font-weight:600;-fx-cursor:hand;"
                        text="🎓 Étudiant"/>
                <Button fx:id="btnParent" prefHeight="34.0" prefWidth="100.0"
                        style="-fx-background-color:#059669;-fx-text-fill:white;-fx-background-radius:20px;-fx-font-size:11px;-fx-font-weight:600;-fx-cursor:hand;"
                        text="👨‍👩‍👦 Parent"/>
            </HBox>
            <Label style="-fx-font-size:10px;-fx-text-fill:#d1d5db;" text="Cliquez sur un rôle pour pré-remplir les champs"/>
        </VBox>
    </VBox>

    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>
</VBox>
